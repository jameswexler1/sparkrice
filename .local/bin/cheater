#!/bin/bash

IMG="/tmp/ocr_gemini.png"
TXT="/tmp/ocr_gemini.txt"
CONTEXT_FILE="/tmp/gemini_context.txt"
LOG="/tmp/gem.log"

# 1. Screenshot selection
maim -s "$IMG" || exit 1

# 2. OCR
tesseract "$IMG" "${TXT%.txt}" --psm 6 --dpi 300 -l eng
TEXT=$(cat "$TXT" | sed '/^[[:space:]]*$/d' | sed '/^[A-Z]{9,}$/d')

# 3. Build dmenu prompt label
CONTEXT_LABEL=""
[ -f "$CONTEXT_FILE" ] && CONTEXT_LABEL=" [ctx]"

# 4. First dmenu: pick mode
MODEL=$(printf "flash\npro\nopen\nwith context\nadd context" \
    | dmenu -i -p "Model${CONTEXT_LABEL}:")
[ -z "$MODEL" ] && exit 0

# 5. Add context: append OCR text to context file and exit
if [ "$MODEL" = "add context" ]; then
    echo "$TEXT" >> "$CONTEXT_FILE"
    echo "[$(date)] Context updated: $(wc -w < "$CONTEXT_FILE") words saved." >> "$LOG"
    exit 0
fi

# 6. With context: second dmenu to pick question type
if [ "$MODEL" = "with context" ]; then
    if [ ! -f "$CONTEXT_FILE" ] || [ ! -s "$CONTEXT_FILE" ]; then
        echo "[$(date)] ERROR: 'with context' selected but no context file found." >> "$LOG"
        exit 1
    fi
    SUBMODEL=$(printf "flash\nopen" | dmenu -i -p "Question type? (flash=MCQ letter, open=essay):")
    [ -z "$SUBMODEL" ] && exit 0
    ANSWER=$(echo "$TEXT" | ~/.local/bin/askgemini.py --model "$SUBMODEL" --context-file "$CONTEXT_FILE")
else
    # 7. Normal query
    ANSWER=$(echo "$TEXT" | ~/.local/bin/askgemini.py --model "$MODEL")
fi

# 8. Show in dmenu
if echo "$ANSWER" | grep -q '^\*'; then
    echo "$ANSWER" | sed 's/^\* \+//' | dmenu -i -p "Hehe:"
else
    clean=$(echo "$ANSWER" | tr '\n' ' ' | sed 's/  */ /g')
    echo "$clean" | sed 's/\([.!?,;]\)/\1\n/g' | sed '/^[[:space:]]*$/d' | dmenu -i -p "Hehe:"
fi

# 9. Copy to clipboard
echo "$ANSWER" | xclip -selection clipboard
