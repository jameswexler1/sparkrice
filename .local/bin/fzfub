#!/bin/sh

# ueberzugpp stuff
case "$(uname -a)" in
    *Darwin*) UEBERZUG_TMP_DIR="$TMPDIR" ;;
    *) UEBERZUG_TMP_DIR="/tmp" ;;
esac

cleanup() {
    ueberzugpp cmd -s "$SOCKET" -a exit
}
trap cleanup HUP INT QUIT TERM EXIT

UB_PID_FILE="$UEBERZUG_TMP_DIR/.$(uuidgen)"
ueberzugpp layer --no-stdin --silent --use-escape-codes --pid-file "$UB_PID_FILE"
UB_PID=$(cat "$UB_PID_FILE")

export SOCKET="$UEBERZUG_TMP_DIR"/ueberzugpp-"$UB_PID".socket

# fzf optional settings:
# first argument: directory
# second argument: preset options
# third argument: any other options
# example using wallpapermenu opts:
# fzfub ~/pics w --tac

case $2 in
		*w) # wallpapermenu options
			FZFARGS='enter:execute-silent(setbg {})+accept,ctrl-w:execute-silent(setbg {}),ctrl-e:become(gimp {+} > /dev/null 2>&1)'
			ILABEL='wallpaper menu'
			LABEL='[ctrl-w: set wallpaper | ctrl-e: open in gimp]' ;;
		*m) # вӮҠвҠ№ЙӘбҙҚЙўбҙҚЙўбҙӢвҠ№вӮҠ options
				FZFARGS='ctrl-r:become(fzfubrefresh {}),ctrl-j:execute-silent(imgmgk jpg {}),ctrl-p:execute-silent(imgmgk png {}),ctrl-d:execute(rm -i {} && notify-send {} deleted),ctrl-s:execute-silent(imgmgk scale {+}),ctrl-b:execute-silent(imgmgk bw {+}),ctrl-w:execute-silent(imgmgk wm {+}),ctrl-g:become(gimp {+} > /dev/null 2>&1),ctrl-t:execute-silent(imgmgk transparency {+}),ctrl-f:execute-silent(imgmgk flip {+}),ctrl-v:execute-silent(imgmgk vflip {+}),ctrl-l:execute-silent(imgmgk border {+}),ctrl-h:execute-silent(imgmgk wborder {+})'
				ILABEL="[бҙ„бҙӣКҖКҹ: рқҗЈВ·бҙҠбҙҳЙў рқҗ©В·бҙҳЙҙЙў рқҗқВ·бҙ…бҙҮКҹ рқҗ¬В·sбҙ„бҙҖКҹбҙҮ рқҗӣВ·Кҷ&бҙЎ рқҗ°В·бҙЎбҙӣКҖбҙҚбҙҖКҖбҙӢ"
				LABEL="рқҗ В·вһЎЙўЙӘбҙҚбҙҳ рқҗӯВ·бҙӣКҖбҙҖЙҙsбҙҳбҙҖКҖбҙҮЙҙбҙӣ рқҗҹ/рқҗҜВ·Т“КҹЙӘбҙҳ рқҗҘВ·КҷКҹбҙӢ рқҗЎВ·бҙЎКңбҙӣбҙҮ КҷбҙҸКҖбҙ…КҖ]" ;;
		*c) # cliphist options
				ILABEL="бҙ„КҹЙӘбҙҳКңЙӘsбҙӣ: бҙҮЙҙбҙӣбҙҮКҖ/бҙ„бҙӣКҖКҹ-c: бҙ„бҙҸбҙҳКҸ"
				LABEL="[бҙ„бҙӣКҖКҹ g: бҙҮбҙ…ЙӘбҙӣ ЙӘЙҙ ЙўЙӘбҙҚбҙҳ | d: бҙ…бҙҮКҹ | t: бҙӣбҙҸ бҙӣКҖбҙҖЙҙsбҙҳбҙҖКҖбҙҮЙҙбҙӣ]"
				FZFARGS='enter:execute(cliphist copy {}),ctrl-c:execute(cliphist copy {}),ctrl-t:execute-silent(imgmgk transparencyrecopy {+}),ctrl-g:become(gimp {+} > /dev/null 2>&1),ctrl-d:execute(rm {} && notify-send {} deleted)' ;;
		*) FZFARGS='ctrl-d:execute(rm -i {} && notify-send {} deleted)' ;; # normal options
esac

# run fzf with preview and given vars
fzf --walker-root=${1:-$PWD} $3 -m --bind "$FZFARGS" --style ${STYLE:-full} --reverse --preview-border --preview-label "$LABEL" --input-label "$ILABEL" --preview="ueberzugpp cmd -s $SOCKET -i fzfpreview -a add \
                            -x \$FZF_PREVIEW_LEFT -y \$FZF_PREVIEW_TOP \
                            --max-width \$FZF_PREVIEW_COLUMNS --max-height \$FZF_PREVIEW_LINES \
                            -f {} || bat --style=plain--color=always {}"

ueberzugpp cmd -s "$SOCKET" -a exit
